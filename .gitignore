# Prevent committing huge offline bundle
/tina-server.tar.gz

# Local build logs (workspace noise)
/build_log*.txt

# Local toolchain archive (moved stale asset packs, not for commit/package)
app/.local/
# Legacy wrong path: never archive toolchains under packaged assets
app/src/*/assets/tina-toolchain/archive/

# Do not commit local production env files
/server/tina-admin/.env.production

# Do not commit plaintext tina-server secrets (encrypted *.enc is OK)
/server/tina-server/secrets/*.b64
/server/tina-server/secrets/*.env

# xCrash local module build artifacts
/external/xcrash/.cxx/
/external/xcrash/build/
/external/tina-exec/runtime/.cmake-smoke-*/


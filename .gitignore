# PRoot assets
# 注意：proot 二进制文件和 libtalloc 需要提交到仓库以支持 CI/CD 构建
# rootfs.tar.gz 是大文件，仍然忽略（用户需要自行下载或构建）
#
# 新架构：使用 productFlavors，资源放在架构特定的 flavor 目录
# app/src/arm64/assets/proot/arm64-v8a/rootfs.tar.gz (或 .tar_gz)
# app/src/x86_64/assets/proot/x86_64/rootfs.tar.gz (或 .tar_gz)
app/src/*/assets/proot/**/*.tar.gz
app/src/*/assets/proot/**/*.tar_gz

# 旧路径（已废弃，但保留规则以防遗留文件）
app/src/main/assets/proot/**/*.tar.gz
app/src/main/assets/proot/**/*.tar_gz

# 以下文件需要提交以支持 CI/CD
# app/src/main/assets/proot/**/proot
# app/src/main/assets/proot/**/*.so*

# Local LLVM source trees (do not commit huge upstream repos)
llvm_projects/
llvm-project/
llvm-projects/

# App 集成的 LLVM 库（由同步脚本生成，不提交）
app/src/main/jniLibs/**/libLLVM*.so
app/src/main/jniLibs/**/libclang*.so
app/src/main/jniLibs/**/liblld*.so
app/src/main/jniLibs/**/libc++_shared.so

# Sysroot（由同步脚本生成，不提交）
app/src/main/assets/sysroot/
app/src/main/assets/*.zip
!app/src/main/assets/xmake-overrides/**

# Generated LLVM build artifacts (headers/libs/sysroot)
external/llvm-build-libs/
!external/llvm-build-libs/README.md

